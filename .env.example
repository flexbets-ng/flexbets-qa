# ──────────────────────────────────────────────
# BrowserStack Credentials
# ──────────────────────────────────────────────
BROWSERSTACK_USERNAME=your_username_here
BROWSERSTACK_ACCESS_KEY=your_access_key_here

# ──────────────────────────────────────────────
# App URLs (returned by BrowserStack after upload)
# ──────────────────────────────────────────────
BROWSERSTACK_ANDROID_APP_URL=bs://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BROWSERSTACK_IOS_APP_URL=bs://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# Jira (flexbets.atlassian.net)
# ──────────────────────────────────────────────
JIRA_BASE_URL=https://flexbets.atlassian.net
JIRA_EMAIL=your-jira-email@flexbets.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=FLEX
JIRA_AUTO_FILE_BUGS=true

# ──────────────────────────────────────────────
# MailSlurp (qa.flexbets.io)
# ──────────────────────────────────────────────
# Automated mailboxes: qa1@qa.flexbets.io → qa10@qa.flexbets.io
# App Live mailboxes:  live1@qa.flexbets.io, live2@qa.flexbets.io
MAILSLURP_API_KEY=your_mailslurp_api_key

# ──────────────────────────────────────────────
# FlexBets App Config
# ──────────────────────────────────────────────
FLEXBETS_API_BASE_URL=https://api.staging.flexbets.com
# Automated test accounts (use qa1–qa10 mailboxes)
FLEXBETS_TEST_USER_EMAIL=qa1@qa.flexbets.io
FLEXBETS_TEST_USER_PASSWORD=TestPass123!
FLEXBETS_TEST_USER_PIN=1234
# App Live manual test accounts
FLEXBETS_LIVE1_EMAIL=live1@qa.flexbets.io
FLEXBETS_LIVE2_EMAIL=live2@qa.flexbets.io

# ──────────────────────────────────────────────
# Test Execution
# ──────────────────────────────────────────────
TEST_ENV=staging
LOG_LEVEL=info
SCREENSHOT_ON_FAILURE=true
VIDEO_RECORDING=true
