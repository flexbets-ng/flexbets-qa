# BrowserStack credentials (BrowserStack Profile)
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=

# BrowserStack metadata
BS_PROJECT=FlexBets_QA
BS_BUILD_TAG=manual

# What to execute in the suite (path inside maestro_suite)
BS_EXECUTE=flows/smoke

# Optional: override device lists (must be valid BrowserStack device strings)
# BS_DEVICES_ANDROID='["Google Pixel 7-13.0","Samsung Galaxy S22-12.0"]'
# BS_DEVICES_IOS='["iPhone 15-17"]'

# Test credentials (use a dedicated test user without OTP/MFA if possible)
TEST_EMAIL=
TEST_PASSWORD=
