{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node", "@wdio/mocha-framework", "@wdio/browserstack-service"]
  },
  "include": ["config/**/*.ts", "tests/**/*.ts", "pages/**/*.ts", "helpers/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
