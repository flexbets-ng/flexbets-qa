{
  "name": "flexbets-qa",
  "version": "1.0.0",
  "description": "Full QA environment for FlexBets mobile app on BrowserStack",
  "scripts": {
    "test:android": "wdio run config/wdio.android.conf.ts",
    "test:ios": "wdio run config/wdio.ios.conf.ts",
    "test:android:bs": "wdio run config/wdio.android.bs.conf.ts",
    "test:ios:bs": "wdio run config/wdio.ios.bs.conf.ts",
    "test:all:bs": "npm run test:android:bs && npm run test:ios:bs",
    "test:smoke": "wdio run config/wdio.android.bs.conf.ts --suite smoke",
    "test:regression": "wdio run config/wdio.android.bs.conf.ts --suite regression",
    "upload:app:android": "ts-node scripts/upload-app.ts android",
    "upload:app:ios": "ts-node scripts/upload-app.ts ios",
    "generate:report": "allure generate allure-results --clean -o allure-report && allure open",
    "lint": "eslint tests/ pages/ --ext .ts",
    "clean": "rimraf allure-results allure-report"
  },
  "dependencies": {
    "@wdio/allure-reporter": "^8.29.0",
    "@wdio/appium-service": "^8.29.0",
    "@wdio/browserstack-service": "^8.29.0",
    "@wdio/cli": "^8.29.0",
    "@wdio/local-runner": "^8.29.0",
    "@wdio/mocha-framework": "^8.29.0",
    "@wdio/spec-reporter": "^8.29.0",
    "appium": "^2.4.0",
    "appium-uiautomator2-driver": "^3.0.0",
    "appium-xcuitest-driver": "^7.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.0",
    "mailslurp-client": "^15.20.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "allure-commandline": "^2.25.0",
    "eslint": "^8.50.0"
  }
}
